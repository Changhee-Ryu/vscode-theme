{
  "name": "eye-friendly-paper",
  "displayName": "Eye-Friendly Paper Themes",
  "description": "A collection of comfortable, paper-inspired themes for optimal eye comfort and readability.",
  "version": "1.0.2",
  "icon": "icon.png",
  "publisher": "Changhee-Ryu",
  "repository": {
    "type": "git",
    "url": "https://github.com/Changhee-Ryu/vscode-theme.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "scripts": {
    "package": "vsce package",
    "postpackage": "mkdir -p dist && mv *.vsix dist/",
    "package:install": "code --install-extension dist/*.vsix"
  },
  "contributes": {
    "themes": [
      {
        "label": "Eye-Friendly Paper Light",
        "uiTheme": "vs",
        "path": "./themes/paper-light-color-theme.json"
      },
      {
        "label": "Eye-Friendly Paper Dark Green",
        "uiTheme": "vs-dark",
        "path": "./themes/paper-dark-green-color-theme.json"
      },
      {
        "label": "Eye-Friendly Paper Dark Sepia",
        "uiTheme": "vs-dark",
        "path": "./themes/paper-dark-sepia-color-theme.json"
      }
    ],
    "markdown.previewStyles": [
      "./themes/markdown-preview.css"
    ]
  }
}