        "editor.foreground": "#E4EBE0",
        "editor.lineHighlightBackground": "#3F4B3F",
        "editor.selectionBackground": "#3C4E3C",
        "editor.inactiveSelectionBackground": "#3C4E3C80",
        "editorCursor.foreground": "#E4EBE0",
        "editorWhitespace.foreground": "#495749",
        "editorIndentGuide.background1": "#3C443C",
        "editorIndentGuide.activeBackground1": "#6A7C6A",
        "scrollbarSlider.background": "#E4EBE015",
        "scrollbarSlider.hoverBackground": "#E4EBE025",
